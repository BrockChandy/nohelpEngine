// GAME ENGINE.cpp : This file contains the 'main' function. Program execution begins and ends there.
//
#include <thread>
#include <chrono>
#include <iostream>

void pause(int ms) {
    std::this_thread::sleep_for(std::chrono::milliseconds(ms));
}

int main()
{
//First iteration of engine
    int goalamount = 0;
    int shotamount = 0;
    while (goalamount == 0) {
        srand(static_cast<unsigned int>(time(0)));
        int randomNum = rand() % 21;
        if (randomNum >= 15) {
            std::cout << "GOAL, number was " << randomNum << std::endl;
            goalamount = goalamount + 1;
            shotamount = shotamount + 1;
        }
        else {
            std::cout << "NO GOAL, number was " << randomNum << std::endl;
            shotamount = shotamount + 1;
        }
        std::cout << goalamount << std::endl;
        std::cout << shotamount << std::endl;
        pause(1000);
    }
}

